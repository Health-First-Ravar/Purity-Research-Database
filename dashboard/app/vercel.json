{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/update/cron", "schedule": "0 10 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "app/api/chat/route.ts":          { "maxDuration": 30 },
    "app/api/audit/route.ts":         { "maxDuration": 30 },
    "app/api/reva/route.ts":          { "maxDuration": 60 },
    "app/api/reva-helper/route.ts":   { "maxDuration": 15 },
    "app/api/update/cron/route.ts":   { "maxDuration": 300 }
  }
}
