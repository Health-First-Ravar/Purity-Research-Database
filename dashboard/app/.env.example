# ---------------------------------------------------------------------------
# Purity Dashboard — environment variables
# Copy to .env.local for local dev. Never commit the filled-in file.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + Auth + Storage + pgvector) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose client-side

# --- Anthropic (Claude Sonnet 4.6 for generation, Haiku 4.5 for classification) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_GENERATE=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# --- Voyage AI (voyage-3-large, 1024-dim embeddings) ---
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

# --- Google Drive (for COA / PDF sync; service account recommended) ---
GOOGLE_SERVICE_ACCOUNT_JSON=           # inline JSON or path to JSON key file
DRIVE_COA_FOLDER_ID=                   # folder id where new COAs land
DRIVE_RESEARCH_FOLDER_ID=              # "Research for AI Project"
DRIVE_PRODUCT_PDF_FOLDER_ID=

# --- Cron / manual-update secret (shared between Vercel Cron + API route) ---
CRON_SECRET=generate-a-long-random-string

# --- App config ---
NEXT_PUBLIC_APP_NAME="Purity Dashboard"
NEXT_PUBLIC_APP_URL=http://localhost:3000
MANUAL_UPDATE_DAILY_CAP=3
CANON_MATCH_THRESHOLD=0.82              # cosine sim; above this = canon hit
CHUNK_MATCH_THRESHOLD=0.55
RETRIEVAL_TOP_K=8

# --- Observability (optional but recommended) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Reddit scraping (seed-pipeline; server-only) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="purity-dashboard-seed/0.1 by u/your-username"

# --- Open-access PDF fetcher (seed-pipeline/fetch_oa_pdfs.py) ---
# Required for Unpaywall API. Use a real email — they block anonymous.
UNPAYWALL_EMAIL=jravar@puritycoffee.com
# Optional NCBI API key raises ID-Converter rate limit from 3/s → 10/s
NCBI_API_KEY=
# Where downloaded PDFs + .txt land
BIBLIOGRAPHY_PDF_ROOT=/sessions/confident-sweet-brahmagupta/mnt/Purity-Lab-Data/knowledge-base/bibliography/pdfs
